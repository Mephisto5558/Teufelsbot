{
  "name": "teufelsbot",
  "version": "1.0.0",
  "description": "A discord.js v14 bot with Dashboard, multiple language support, a DB and many commands, in active development.",
  "keywords": [
    "discord",
    "discord-bot",
    "discordjs"
  ],
  "homepage": "https://github.com/Mephisto5558/Teufelsbot#readme",
  "bugs": {
    "url": "https://github.com/Mephisto5558/Teufelsbot/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mephisto5558/Teufelsbot.git"
  },
  "license": "MIT",
  "author": "Mephisto5558",
  "type": "module",
  "files": [],
  "imports": {
    "#utils": "./src/utils/index.js",
    "#utils/combinedCommands": "./src/utils/combinedCommands/index.js",
    "#utils/componentHandler": "./src/utils/componentHandler/index.js",
    "#utils/prototypeRegisterer": "./src/utils/prototypeRegisterer/index.js",
    "#utils/*": "./src/utils/*"
  },
  "main": "src/index.js",
  "types": "./src/types/globals.d.ts",
  "scripts": {
    "lint": "eslint . --cache --cache-location ./node_modules/.cache/eslint/ >eslint.log",
    "lint:check-time": "(export TIMING=50 2>nul || set TIMING=50) && eslint --no-cache -o eslint.log >eslint-timings.md",
    "lint:no-cache": "npm run lint -- --no-cache",
    "test": "npm run test:file \"./Tests/**/*.mjs\"",
    "test:file": "node --test --stack-trace-limit=1 --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=Tests/lcov.info --test-coverage-exclude=Tests/** --import ./Tests/setup.mjs --"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "@mephisto5558/better-types": "latest",
    "@mephisto5558/bot-website": "latest",
    "@mephisto5558/command": "file:../command/mephisto5558-command-0.7.1-0.tgz",
    "@mephisto5558/i18n": "2.x",
    "@mephisto5558/mongoose-db": "latest",
    "@snazzah/davey": "^0.1.11",
    "cron": "^4.4.0",
    "discord-giveaways": "^6.0.1",
    "discord-tictactoe": "^4.2.2",
    "discord.js": "^14.26.4",
    "fast-average-color-node": "^3.2.0",
    "ffmpeg-static": "^5.3.0",
    "mathjs": "^15.2.0",
    "node-fetch": "^3.3.2",
    "opusscript": "0.0.x",
    "pokedex-promise-v2": "4.2.3",
    "prism-media": "^1.3.5",
    "skia-canvas": "^3.0.8",
    "type-better-ms": "^0.2.4",
    "wikijs": "^6.4.1"
  },
  "devDependencies": {
    "@mephisto5558/eslint-config": "latest",
    "@types/express": "5.x",
    "@types/node": "26.x",
    "@types/passport": "1.x"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "sodium-native": "^5.1.0",
    "zlib-sync": "^0.1.10"
  },
  "engines": {
    "node": ">=26.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "onFail": "error",
      "version": ">=26.0.0"
    }
  },
  "allowScripts": {
    "bufferutil@4.1.0": true,
    "ffmpeg-static@5.3.0": true,
    "sharp@0.34.5": true,
    "skia-canvas@3.0.8": true,
    "sqlite3@5.1.7": true,
    "zlib-sync@0.1.10": true
  }
}
