{
  "extends": "@mephisto5558/eslint-config/tsconfigs/node/tsconfig.check.json",
  "compilerOptions": {
    "lib": ["ESNext", "ESNext.Iterator", "ESNext.Temporal"],
    "paths": {
      "#types/*": [
        "./src/types/*.d.ts"
      ],
      "#types/db": [
        "./src/types/database/index.d.ts"
      ],
      "#types/db/*": [
        "./src/types/database/*.d.ts"
      ],
      "#utils/*": [
        "./src/utils/*"
      ],
      "#utils/combinedCommands": [
        "./src/utils/combinedCommands/*"
      ],
      "#utils/componentHandler": [
        "./src/utils/componentHandler/*"
      ],
      "#utils/prototypeRegisterer": [
        "./src/utils/prototypeRegisterer/*"
      ]
    },
    "allowJs": true,
    "types": ["express", "node", "passport"]
  }
}