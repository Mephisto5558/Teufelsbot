{
  "extends": "@mephisto5558/eslint-config/tsconfigs/node/tsconfig.check.json",
  "compilerOptions": {
    "lib": ["ESNext", "ESNext.Iterator", "ESNext.Temporal"],
    "paths": {
      "#types/*": [
        "./src/types/*.d.ts"
      ],
      "#types/db": [
        "./src/types/database/index.ts"
      ],
      "#types/db/*": [
        "./src/types/database/*.d.ts"
      ],
      "#utils/*": [
        "./src/utils/*.d.ts",
        "./src/utils/*.js"
      ],
      "#utils/combinedCommands": [
        "./src/utils/combinedCommands/*.d.ts",
        "./src/utils/combinedCommands/*.js"
      ],
      "#utils/componentHandler": [
        "./src/utils/componentHandler/*.d.ts",
        "./src/utils/componentHandler/*.js"
      ],
      "#utils/prototypeRegisterer": [
        "./src/utils/prototypeRegisterer/*.d.ts",
        "./src/utils/prototypeRegisterer/*.js"
      ]
    },
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "types": ["express", "node", "passport"]
  }
}